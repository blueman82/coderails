# macOS
.DS_Store

# remember-plugin session scratch (machine-local handoff/history buffers)
.remember/

# runtime hook logs (machine-local, not source)
logs/

# subagent-driven-development progress ledger (machine-local coordination scratch)
.coderails/

# per-project workflow config — local, may hold project-specific (e.g. Jira) values; never commit to the generic repo
.claude/
**/workflow.config.yaml

# machine-local git worktree dirs
.worktrees

# local-only public-release planning notes (do not publish)
docs/public-readiness-plan.md
docs/public-readiness-spec.md
docs/public-readiness-plan-v2.md

# task-evals working artifact — PR-scope working material only, never a durable artifact (that's the PR comment)
/evals.json

# design specs and implementation plans — session-local working docs, never tracked in the repo
docs/coderails/specs/
docs/coderails/plans/

# local-only competitive-analysis working notes (do not publish)
docs/agent-stack-comparison-*.md
