{
  "repos": ["blueman82/coderails"],
  "wikiPaths": ["/path/to/coderails-wiki"],
  "buttons": [
    {
      "name": "wiki-lint",
      "label": "WIKI LINT",
      "command": "/coderails:wiki-lint",
      "cwd": "/path/to/coderails",
      "profile": "read-only",
      "hidden": true
    },
    {
      "name": "sync-docs",
      "label": "DOCS SYNC",
      "command": "/coderails:docs-sync",
      "cwd": "/path/to/coderails",
      "profile": "bypass",
      "bypassPermissions": true,
      "hidden": true
    },
    {
      "name": "memory-consolidation-weekly",
      "label": "MEMORY CONSOLIDATION",
      "command": "/coderails:memory-consolidation",
      "cwd": "/path/to/coderails",
      "profile": "read-only",
      "hidden": true
    },
    {
      "name": "ask",
      "label": "ASK",
      "command": "",
      "cwd": "/path/to/coderails",
      "profile": "auto",
      "inputAllowed": true
    },
    {
      "name": "loop-retro-promotion",
      "label": "LOOP RETRO PROMOTION",
      "command": "/coderails:loop-retro-promotion",
      "cwd": "/path/to/coderails",
      "profile": "bypass",
      "bypassPermissions": true,
      "hidden": true
    },
    {
      "name": "inbox-brief",
      "label": "INBOX BRIEF",
      "command": "Run exactly this command via the Bash tool: bin/rachel \"Read tasks/inbox-brief.md and follow it.\" < /dev/null . Its output will end with a line `BRIEF FILE: <path>`. Read that file and make your ENTIRE final message exactly its contents — nothing before it, nothing after it, no preamble, no code fence. If no `BRIEF FILE:` line appears (delivery failed or the sweep was skipped), instead report Rachel's stated outcome in a single line.",
      "cwd": "/path/to/assistant-agent",
      "profile": "bypass",
      "bypassPermissions": true
    },
    {
      "name": "workflow-audit-weekly",
      "label": "WORKFLOW AUDIT (weekly)",
      "command": "Invoke coderails:workflow-audit in QUEUE-MODE over the last 7 days (--days 7). In-session skill creation is forbidden in this run — every propose verdict is written as a queue entry only. Finish by writing the run note to /path/to/.claude/coderails-dashboard/routines/workflow-audit/run-{date}.md (use exactly this path and filename) recording `proposals_written: <N>` and `proposals_attempted: <A>`, where N counts queue entries actually written this run. Emit the completion marker line `## [<YYYY-MM-DD>] workflow-audit complete` ONLY IF the run finished cleanly AND N == A. If any queue write failed (N != A) or the run did not complete, write the note WITHOUT the completion marker. N=0 with no failures is SUCCESS — emit the marker.",
      "cwd": "/path/to/coderails",
      "profile": "read-only",
      "hidden": true
    }
  ],
  "routines": [
    {
      "name": "wiki-lint",
      "label": "Wiki Lint (nightly)",
      "buttonRef": "wiki-lint",
      "cadence": "nightly",
      "expectedArtifact": {
        "artifactPath": "{vault}/log.md",
        "maxAgeSeconds": 129600,
        "predicate": { "kind": "contains", "marker": "## [{date}] lint" }
      },
      "escalation": ["notification", "vault-note"]
    },
    {
      "name": "sync-docs-nightly",
      "label": "Docs Sync (nightly)",
      "buttonRef": "sync-docs",
      "cadence": "nightly",
      "expectedArtifact": {
        "artifactPath": "/path/to/.claude/coderails-dashboard/routines/docs-sync/run-{date}.log",
        "maxAgeSeconds": 129600,
        "predicate": { "kind": "exists" }
      },
      "escalation": ["notification", "vault-note"]
    },
    {
      "name": "memory-consolidation-weekly",
      "label": "Memory Consolidation (weekly)",
      "buttonRef": "memory-consolidation-weekly",
      "cadence": "weekly",
      "expectedArtifact": {
        "artifactPath": "/path/to/.claude/coderails-dashboard/routines/memory-consolidation/report-{date}.md",
        "maxAgeSeconds": 691200,
        "predicate": { "kind": "exists" }
      },
      "escalation": ["notification", "vault-note"]
    },
    {
      "name": "loop-retro-promotion-weekly",
      "label": "Loop Retro Promotion (weekly)",
      "buttonRef": "loop-retro-promotion",
      "cadence": "weekly",
      "expectedArtifact": {
        "artifactPath": "/path/to/.claude/agentic-loop/-path-to-coderails-.git/promotion-runs.log",
        "maxAgeSeconds": 691200,
        "predicate": { "kind": "exists" }
      },
      "escalation": ["notification", "vault-note"]
    },
    {
      "name": "workflow-audit-weekly",
      "label": "Workflow Audit (weekly)",
      "buttonRef": "workflow-audit-weekly",
      "cadence": "weekly",
      "expectedArtifact": {
        "artifactPath": "/path/to/.claude/coderails-dashboard/routines/workflow-audit/run-{date}.md",
        "maxAgeSeconds": 691200,
        "predicate": { "kind": "contains", "marker": "## [{date}] workflow-audit complete" }
      },
      "escalation": ["notification", "vault-note"]
    }
  ]
}
