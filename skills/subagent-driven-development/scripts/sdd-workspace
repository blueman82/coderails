#!/usr/bin/env bash
# Resolve and ensure the working-tree-independent directory SDD uses for its
# short-lived artifacts: task briefs, implementer reports, review packages,
# and the progress ledger (sdd-ledger.md).
#
# Session-keyed, not repo-root-keyed: lives beside progress.json in the
# agentic-loop state dir, resolved via the sole path authority
# hooks/scripts/lib/agentic_loop_path.sh (dirname of its progress.json path).
# This was previously a fixed repo-root subdirectory — repo-root-keyed, so
# every session working in the same repo shared one ledger, a latent bug for
# any two concurrent SDD runs in the same working tree. Session-keying via the
# same helper progress.json already uses gives each session its own ledger,
# with no risk of two sessions' task briefs/reports colliding.
#
# Outside the repo, so no self-ignoring marker file is needed to keep it out
# of `git status` (progress.json's own directory is already outside git's
# view) and `git clean -fdx` can no longer destroy the ledger.
#
# Single source of truth for the workspace location, so task-brief and
# review-package cannot drift to different directories.
#
# Usage: sdd-workspace
set -euo pipefail

# The helper's per-call unknown-$$ fallback (when no session_id is available)
# is correct for Stop-hook callers but non-idempotent here: a different dir
# per call would mean an empty ledger on every re-dispatch, the exact failure
# this script exists to prevent. Fail loud instead of silently degrading.
if [ -z "${CLAUDE_CODE_SESSION_ID:-}" ]; then
  echo "sdd-workspace: CLAUDE_CODE_SESSION_ID is unset or empty; refusing to resolve a non-idempotent fallback path" >&2
  exit 1
fi

progress_path=$(bash "$(cd "$(dirname "$0")/../../.." && pwd)/hooks/scripts/lib/agentic_loop_path.sh")

# Empty/garbage stdout on exit 0 would otherwise degrade silently to cwd via dirname.
[[ "$progress_path" == /* ]] || { echo "sdd-workspace: agentic_loop_path.sh returned non-path output: '$progress_path'" >&2; exit 1; }

dir=$(dirname "$progress_path")
mkdir -p "$dir"
cd "$dir" && pwd
